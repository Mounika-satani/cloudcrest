{
    "headers": [
        {
            "source": "/(.*).ics",
            "headers": [
                {
                    "key": "Content-Type",
                    "value": "text/calendar"
                },
                {
                    "key": "Access-Control-Allow-Origin",
                    "value": "*"
                },
                {
                    "key": "Cache-Control",
                    "value": "no-cache"
                }
            ]
        }
    ],
    "rewrites": [
        {
            "source": "/((?!.*\\.).*)",
            "destination": "/index.html"
        }
    ]
}